{
  "name": "jonathanobino.github.com",
  "version": "0.1.0",
  "description": "Website development with react",
  "source": "templates/index.html",
  "scripts": {
    "prettier": "prettier ./src/*/*.js ./src/*.js ./src/scss/style.scss -w --single-quote",
    "build": "npm run clean-docs && npm run clean-prerender && parcel build --dist-dir ./docs --no-content-hash && npm run prerender:bundle && npm run prerender:inject",
    "start": "npm run clean-dist && npm run clean-cache && NODE_ENV=DEV parcel serve ",
    "dev:network": "parcel serve --host 0.0.0.0",
    "clean-docs": "rm -rf docs",
    "clean-prerender": "rm -rf .prerender",
    "clean-dist": "rm -rf dist",
    "clean-cache": "rm -rf .parcel-cache",
    "server": "parcel build server.js --dist-dir ./server",
    "prerender:bundle": "parcel build server.js --dist-dir ./.prerender --no-content-hash",
    "prerender:inject": "node ./scripts/inject-prerender.mjs",
    "lint": "biome lint src/* src/*/*",
    "format": "biome format --write ./src/*/*.js ./src/*.js",
    "preview": "npx serve docs -l 4173"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonathanobino/jonathanobino.github.com.git"
  },
  "keywords": [
    "react",
    "parcel",
    "es6",
    "modulized",
    "catpuccin"
  ],
  "author": "Jonathan Obino",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jonathanobino/jonathanobino.github.com/issues"
  },
  "homepage": "https://github.com/jonathanobino/jonathanobino.github.com#readme",
  "dependencies": {
    "lazy-react": "^3.6.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.18.9",
    "@biomejs/biome": "^2.3.11",
    "@parcel/transformer-sass": "^2.6.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "parcel": "^2.6.2",
    "parcel-reporter-static-files-copy": "^1.3.4",
    "process": "^0.11.10"
  }
}
